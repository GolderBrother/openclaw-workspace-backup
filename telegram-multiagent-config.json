# Telegram 多 Agent 配置方案

## 1. Telegram Bot 配置结构

需要在 `channels.telegram.accounts` 下为每个 agent 配置独立的 bot：

```json
"channels": {
  "telegram": {
    "enabled": true,
    "accounts": {
      "xiaomei": {
        "enabled": true,
        "botToken": "YOUR_XIAOMEI_BOT_TOKEN",
        "markdownSupport": true
      },
      "xiaoma": {
        "enabled": true,
        "botToken": "YOUR_XIAOMA_BOT_TOKEN",
        "markdownSupport": true
      },
      "xiaohua": {
        "enabled": true,
        "botToken": "YOUR_XIAOHUA_BOT_TOKEN",
        "markdownSupport": true
      },
      "xiaobi": {
        "enabled": true,
        "botToken": "YOUR_XIAOBI_BOT_TOKEN",
        "markdownSupport": true
      },
      "xiaozhang": {
        "enabled": true,
        "botToken": "YOUR_XIAOZHANG_BOT_TOKEN",
        "markdownSupport": true
      },
      "xiaofeng": {
        "enabled": true,
        "botToken": "YOUR_XIAOFENG_BOT_TOKEN",
        "markdownSupport": true
      },
      "xiaomei_media": {
        "enabled": true,
        "botToken": "YOUR_XIAOMEI_MEDIA_BOT_TOKEN",
        "markdownSupport": true
      },
      "xiaodun": {
        "enabled": true,
        "botToken": "YOUR_XIAODUN_BOT_TOKEN",
        "markdownSupport": true
      }
    }
  }
}
```

## 2. Agent 绑定配置

需要在 `bindings` 数组中添加 telegram 绑定：

```json
"bindings": [
  // 现有的飞书、QQbot 绑定...
  {
    "agentId": "main",
    "match": { "channel": "feishu", "accountId": "main" }
  },
  {
    "agentId": "dev",
    "match": { "channel": "feishu", "accountId": "dev" }
  },
  // ... 其他飞书绑定

  // Telegram 绑定（新增）
  {
    "agentId": "main",
    "match": { "channel": "telegram", "accountId": "xiaomei" }
  },
  {
    "agentId": "dev",
    "match": { "channel": "telegram", "accountId": "xiaoma" }
  },
  {
    "agentId": "design",
    "match": { "channel": "telegram", "accountId": "xiaohua" }
  },
  {
    "agentId": "content",
    "match": { "channel": "telegram", "accountId": "xiaobi" }
  },
  {
    "agentId": "finance",
    "match": { "channel": "telegram", "accountId": "xiaozhang" }
  },
  {
    "agentId": "growth",
    "match": { "channel": "telegram", "accountId": "xiaofeng" }
  },
  {
    "agentId": "media",
    "match": { "channel": "telegram", "accountId": "xiaomei_media" }
  },
  {
    "agentId": "legal",
    "match": { "channel": "telegram", "accountId": "xiaodun" }
  }
]
```

