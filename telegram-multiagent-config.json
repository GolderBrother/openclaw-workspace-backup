    { "id": "finance", "name": "小账", "workspace": "/root/.openclaw/workspace/workspace-finance", "agentDir": "/root/.openclaw/agents/finance" },
    { "id": "growth", "name": "小风", "workspace": "/root/.openclaw/workspace/workspace-growth", "agentDir": "/root/.openclaw/agents/growth" },
